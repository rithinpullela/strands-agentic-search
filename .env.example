# ── LLM provider (Strands default = Amazon Bedrock / Claude) ──────────────────
LLM_PROVIDER=bedrock
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
AWS_REGION=us-west-2
LLM_TEMPERATURE=0
# AWS creds resolved by boto3 (env / shared profile / role). For local runs:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...

# ── QueryPlanningTool ─────────────────────────────────────────────────────────
QPT_GENERATION_TYPE=llmGenerated
# JSONPath into the raw model envelope. Bedrock Converse (Claude):
QPT_RESPONSE_FILTER=$.output.message.content[0].text
# OpenAI would be: $.choices[0].message.content
# Optional fallback DSL override (defaults to {"size":10,"query":{"match_all":{}}}):
# QPT_FALLBACK_QUERY={"size":10,"query":{"match_all":{}}}

# ── OpenSearch MCP server (opensearch-mcp-server-py, launched over stdio) ──────
# Connection details are consumed by the MCP server, not by our code.
# Default: launch with the current interpreter (version matches the installed dep).
#   MCP_COMMAND defaults to the running python; MCP_ARGS to "-m mcp_server_opensearch".
# To use uvx instead, uncomment:
# MCP_COMMAND=uvx
# MCP_ARGS=opensearch-mcp-server-py
MCP_ALLOWED_TOOLS=ListIndexTool,IndexMappingTool,SearchIndexTool,GetIndexInfoTool

# ── OpenSearch connection (passed through to the MCP server) ──────────────────
OPENSEARCH_URL=http://localhost:9200
# Basic auth (leave blank to use no-auth for a local dev cluster):
# OPENSEARCH_USERNAME=admin
# OPENSEARCH_PASSWORD=admin
OPENSEARCH_NO_AUTH=true
OPENSEARCH_SSL_VERIFY=false

# ── HTTP server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
